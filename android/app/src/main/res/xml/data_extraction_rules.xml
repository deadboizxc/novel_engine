<?xml version="1.0" encoding="utf-8"?>
<!--
    Правила извлечения данных для Android 12+
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="saves/" />
        <include domain="file" path="config.json" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="saves/" />
        <include domain="file" path="config.json" />
    </device-transfer>
</data-extraction-rules>
