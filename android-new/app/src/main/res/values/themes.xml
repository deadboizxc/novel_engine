<?xml version="1.0" encoding="utf-8"?>
<!--
    =============================================================================
    TUI Novel - Тема приложения (Хакерский терминал)
    =============================================================================
-->
<resources>
    <!-- Базовая тёмная тема терминала -->
    <style name="Theme.TuiNovel" parent="android:Theme.Material.NoActionBar">
        <!-- Цвета терминала -->
        <item name="android:colorPrimary">#00FF00</item>
        <item name="android:colorPrimaryDark">#000000</item>
        <item name="android:colorAccent">#00FF00</item>
        
        <!-- Полностью чёрный фон -->
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorBackground">@android:color/black</item>
        
        <!-- Полноэкранный режим -->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        
        <!-- Статус-бар -->
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Текст -->
        <item name="android:textColor">#00FF00</item>
    </style>
</resources>
